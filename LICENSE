function swTab(tab){S.mode=tab;document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('a'));document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('a'));document.getElementById(tab==='quest'?'tabQuest':'tabPuzzle').classList.add('a');document.getElementById(tab==='quest'?'tcQuest':'tcPuzzle').classList.add('a');}

function switchScr(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}
function goMap(){switchScr('mapScr');S.current=null;}

function buildMap(){const map=document.getElementById('mapW');const zones=ZONES.filter(z=>z.lang===S.lang);let h=`<div class="map-hdr"><div class="map-title">${t(S.lang==='python'?'mapTitle_py':'mapTitle_js')}</div><div class="map-sub">${t('mapSub')}</div></div><div class="world-path">`;let lc='';
zones.forEach((z,i)=>{const done=S.completed.has(z.id);const prev=i===0||S.completed.has(zones[i-1].id);const locked=!prev&&!done;const cls=done?'done':(locked?'locked':'');const cat=L(z,'cat');if(cat!==lc){if(lc)h+=`<div class="pcon ${done?'done':''}"></div>`;h+=`<div class="msec">${cat}</div>`;lc=cat;}else h+=`<div class="pcon ${done?'done':''}"></div>`;h+=`<div class="zn ${cls}" ${locked?'':'onclick="openZ(\''+z.id+'\')"'}><div class="zn-icon">${z.icon}</div><div class="zn-info"><div class="zn-cat">${cat}</div><div class="zn-nm">${L(z,'title')}</div><div class="zn-desc">${L(z,'desc')}</div></div><div class="zn-rt"><div class="zn-xp">+${z.xp} XP</div><div class="zn-st">${done?'⭐':(locked?'🔒':'▶️')}</div></div></div>`;});
h+='</div>';
// Congratulations banner if all done
const allDone=zones.every(z=>S.completed.has(z.id));
if(allDone&&zones.length>0){h+=`<div class="complete-banner"><div class="cb-icon">🏆</div><div class="cb-title">${S.i18n==='sv'?'ALLA UPPDRAG KLARADE!':'ALL QUESTS COMPLETE!'}</div><div class="cb-sub">${S.i18n==='sv'?'Du är en kodlegend! Prova pusslen eller byt språk för en ny utmaning.':'You are a code legend! Try the puzzles or switch languages for a new challenge.'}</div></div>`;}
map.innerHTML=h;}

function buildPuzzles(){const w=document.getElementById('pzW');const pzs=PUZZLES.filter(p=>p.langs.includes(S.lang));let h=`<div class="map-hdr"><div class="map-title">${t('puzzleTitle')}</div><div class="map-sub">${t('puzzleSub')}</div></div><div class="puzzle-grid">`;
pzs.forEach(p=>{const done=S.completed.has(p.id+'_'+S.lang);const stars='★'.repeat(p.difficulty)+'☆'.repeat(3-p.difficulty);const rawDesc=L(p,'desc').replace(/\n/g,' ');const shortDesc=rawDesc.length>80?rawDesc.substring(0,rawDesc.lastIndexOf(' ',80))+'...':rawDesc;h+=`<div class="pz-card ${done?'done':''}" onclick="openPz('${p.id}')"><div class="pz-top"><span class="pz-icon">${p.icon}</span><span class="pz-diff">${stars}</span></div><div class="pz-nm">${L(p,'title')}</div><div class="pz-desc">${shortDesc}</div><div class="pz-reward">+${p.xp} XP  +${p.coins} 🪙</div></div>`;});
h+='</div>';w.innerHTML=h;}

function openZ(id){const z=ZONES.find(z=>z.id===id);if(!z)return;S.current=id;S.hintUsed=false;
document.getElementById('lesStory').innerHTML=`<span class="s-icon">${z.icon}</span><div class="s-title">${L(z,'title')}</div><div class="s-flavor">${L(z,'flavor')}</div><div class="s-body">${L(z,'body')}<div class="hint-box" id="hintBox"><pre style="margin:0;font-family:inherit;white-space:pre-wrap">${escH(z.hint)}</pre></div></div>`;
document.getElementById('tutorMsg').textContent=L(z,'tutor')||t('tutorWelcome');
document.getElementById('codeIn').value=z.starter;document.getElementById('edTab').textContent=S.lang==='python'?'quest.py':'quest.js';document.getElementById('outC').innerHTML='<span class="oi">'+t('ready')+'</span>';document.getElementById('outSt').textContent='';updLN();switchScr('lesScr');document.getElementById('lesStory').scrollTop=0;charReact('idle');sfx('click');}

function openPz(id){const p=PUZZLES.find(p=>p.id===id);if(!p)return;S.current='puzzle_'+id;S.hintUsed=false;
const hint=S.lang==='python'?p.hint_py:p.hint_js;const starter=S.lang==='python'?p.starter_py:p.starter_js;
document.getElementById('lesStory').innerHTML=`<span class="s-icon">${p.icon}</span><div class="s-title">${L(p,'title')}</div><div class="s-body"><p>${escH(L(p,'desc')).replace(/\n/g,'<br>')}</p><div class="obj"><div class="obj-l">🧩 ${S.i18n==='sv'?'PUSSEL':'PUZZLE'}</div><p>+${p.xp} XP  +${p.coins} 🪙</p></div><div class="hint-box" id="hintBox"><pre style="margin:0;font-family:inherit;white-space:pre-wrap">${escH(hint)}</pre></div></div>`;
