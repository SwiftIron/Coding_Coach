/* === PY TRANSPILER (tested, v3 copy) === */
function pyToJs(src){const lines=src.split('\n'),result=[],bs=[];for(let i=0;i<lines.length;i++){const raw=lines[i],tr=raw.trimEnd();if(!tr||/^\s*#/.test(tr)){result.push('');continue;}const ind=raw.search(/\S/),body=tr.trim(),pad=' '.repeat(ind);while(bs.length>0&&ind<=bs[bs.length-1]){const ci=bs.pop();if(ind===ci&&/^(elif |else\s*:)/.test(body))break;result.push(' '.repeat(ci)+'}');}let m;m=body.match(/^for\s+(\w+)\s+in\s+range\((.+)\)\s*:$/);if(m){const v=m[1],a=m[2].split(',').map(x=>x.trim());let s='0',e,st='1';if(a.length===1)e=a[0];else if(a.length===2){s=a[0];e=a[1];}else{s=a[0];e=a[1];st=a[2];}result.push(`${pad}for(let ${v}=${s};${v}<${e};${v}+=${st}){`);bs.push(ind);continue;}m=body.match(/^for\s+(\w+)\s+in\s+(.+)\s*:$/);if(m){result.push(`${pad}for(let ${m[1]} of ${m[2]}){`);bs.push(ind);continue;}m=body.match(/^while\s+(.+)\s*:$/);if(m){result.push(`${pad}while(${bo(m[1])}){`);bs.push(ind);continue;}m=body.match(/^if\s+(.+)\s*:$/);if(m){result.push(`${pad}if(${bo(m[1])}){`);bs.push(ind);continue;}m=body.match(/^elif\s+(.+)\s*:$/);if(m){result.push(`${pad}}else if(${bo(m[1])}){`);bs.push(ind);continue;}if(/^else\s*:$/.test(body)){result.push(`${pad}}else{`);bs.push(ind);continue;}m=body.match(/^def\s+(\w+)\(([^)]*)\)\s*:$/);if(m){result.push(`${pad}function ${m[1]}(${m[2]}){`);bs.push(ind);continue;}if(body==='pass'){result.push('');continue;}let s=body;
/* f-string: f"...{expr}..." → `...${expr}...` */
s=s.replace(/\bf(["'])(.*?)\1/g,function(_,q,inner){return '`'+inner.replace(/\{/g,'${')+'`';});
/* input() → prompt-like stub */
s=s.replace(/\binput\(([^)]*)\)/g,'(function(){throw new Error("input() is not supported in Code Quest — use variables instead!")})()');
s=s.replace(/\bprint\(/g,'console.log(');s=s.replace(/\blen\(([^)]+)\)/g,'$1.length');s=s.replace(/\bstr\(([^)]+)\)/g,'String($1)');s=s.replace(/\bint\(([^)]+)\)/g,'parseInt($1)');s=s.replace(/\bTrue\b/g,'true').replace(/\bFalse\b/g,'false').replace(/\bNone\b/g,'null');s=s.replace(/\band\b/g,'&&').replace(/\bor\b/g,'||');s=s.replace(/"([^"]+)"\s*\*\s*(\w+)/g,'"$1".repeat($2)');s=s.replace(/'([^']+)'\s*\*\s*(\w+)/g,"'$1'.repeat($2)");s=s.replace(/(\w+)\s*\*\s*"([^"]+)"/g,'"$2".repeat($1)');s=s.replace(/\.append\(/g,'.push(');s=s.replace(/(\w+|\))\[::-1\]/g,'$1.split("").reverse().join("")');s=s.replace(/"([^"]+)"\[::-1\]/g,'"$1".split("").reverse().join("")');s=s.replace(/'([^']+)'\[::-1\]/g,"'$1'.split('').reverse().join('')");s=s.replace(/(\w+)\[(\w+):(\w+)\]/g,'$1.slice($2,$3)');result.push(pad+s);}while(bs.length>0){bs.pop();result.push('}');}return result.join('\n');}
function bo(s){return s.replace(/\bnot\s+in\b/g,'/* not in — use "not x in y" instead */').replace(/\bTrue\b/g,'true').replace(/\bFalse\b/g,'false').replace(/\band\b/g,'&&').replace(/\bor\b/g,'||').replace(/\bnot\b/g,'!');}

const MX=10000;
function addLG(c){let n=0;return c.replace(/(for\s*\([^)]*\)\s*\{|while\s*\([^)]*\)\s*\{)/g,m=>{const v='__l'+(n++)+'__';return'let '+v+'=0;'+m+'if(++'+v+'>__mx__)throw new Error("Loop limit exceeded");';});}
function runPy(code){const cap=[];const ol=console.log;try{let js=addLG(pyToJs(code));console.log=(...a)=>{if(cap.length>500)throw new Error('Too much output');cap.push(a.map(v=>{if(typeof v==='boolean')return v?'True':'False';if(v==null)return'None';if(Array.isArray(v))return'['+v.map(x=>typeof x==='string'?"'"+x+"'":x).join(', ')+']';return String(v);}).join(' '));};new Function('__mx__',js)(MX);console.log=ol;return{out:cap.join('\n'),err:false};}catch(e){console.log=ol;let m=e.message;if(m.includes('Loop limit'))m=t('infLoop');if(m.includes('Too much'))m=t('tooMuchOutput');return{out:'Error: '+m,err:true};}}
function runJs(code){const cap=[];const ol=console.log;try{const g=addLG(code);console.log=(...a)=>{if(cap.length>500)throw new Error('Too much');cap.push(a.map(String).join(' '));};new Function('__mx__',g)(MX);console.log=ol;return{out:cap.join('\n'),err:false};}catch(e){console.log=ol;let m=e.message;if(m.includes('Loop limit'))m=t('infLoop');if(m.includes('Too much'))m=t('tooMuchOutput');return{out:'Error: '+m,err:true};}}
function exec(code){return S.lang==='python'?runPy(code):runJs(code);}

/* === STORAGE === */
let mem={};function cls(){try{localStorage.setItem('_t','1');localStorage.removeItem('_t');return true;}catch(e){return false;}}
const uLS=cls();
function save(){const d=JSON.stringify({...S,completed:[...S.completed]});if(uLS)try{localStorage.setItem('cq4',d);}catch(e){}else mem.cq4=d;}
function load(){try{const r=uLS?localStorage.getItem('cq4'):mem.cq4;if(!r)return;const d=JSON.parse(r);if(d){Object.assign(S,d);S.completed=new Set(d.completed||[]);}}catch(e){}}

