function startTutorial(){
  tutStep=0;tutActive=true;
  document.getElementById('tutOverlay').classList.add('show');
  document.getElementById('tutSkip').classList.add('show');
  document.getElementById('tutSkip').textContent=S.i18n==='sv'?'HOPPA ÖVER GUIDE':'SKIP TUTORIAL';
  showTutStep();
  sfx('click');
}

function showTutStep(){
  const steps=getTutSteps();
  if(tutStep>=steps.length){endTutorial();return;}
  const step=steps[tutStep];
  const spot=document.getElementById('tutSpot');
  const box=document.getElementById('tutBox');
  
  // Position spotlight
  if(step.el){
    const target=document.querySelector(step.el);
    if(target){
      const r=target.getBoundingClientRect();
      spot.style.display='block';
      spot.style.left=(r.left-4)+'px';spot.style.top=(r.top-4)+'px';
      spot.style.width=(r.width+8)+'px';spot.style.height=(r.height+8)+'px';
    } else { spot.style.display='none'; }
  } else { spot.style.display='none'; }
  
  // Build tutorial box
  const dots=steps.map((_,i)=>'<div class="tut-dot'+(i===tutStep?' a':'')+'"></div>').join('');
  const prevBtn=tutStep>0?'<button class="tut-prev" onclick="tutPrev()">'+(S.i18n==='sv'?'← BAKÅT':'← BACK')+'</button>':'<div></div>';
  const isLast=tutStep===steps.length-1;
  const nextBtn='<button class="tut-next" onclick="tutNext()">'+(isLast?(S.i18n==='sv'?'KLAR!':'DONE!'):( S.i18n==='sv'?'NÄSTA →':'NEXT →'))+'</button>';
  
  box.style.display='block';
  box.innerHTML='<h4>'+step.title+'</h4><p>'+step.text+'</p><div class="tut-nav">'+prevBtn+'<div class="tut-dots">'+dots+'</div>'+nextBtn+'</div>';
  
  // Position box relative to spotlight
  if(step.pos==='center'||!step.el){
    box.style.left='50%';box.style.top='50%';box.style.transform='translate(-50%,-50%)';
  } else {
    box.style.transform='none';
    const target=document.querySelector(step.el);
    if(target){
      const r=target.getBoundingClientRect();
      const bw=340;
      if(step.pos==='below'){box.style.left=Math.max(8,Math.min(r.left,innerWidth-bw-8))+'px';box.style.top=(r.bottom+12)+'px';}
      else if(step.pos==='above'){box.style.left=Math.max(8,Math.min(r.left,innerWidth-bw-8))+'px';box.style.top=(r.top-200)+'px';}
      else if(step.pos==='right'){box.style.left=Math.min(r.right+12,innerWidth-bw-8)+'px';box.style.top=r.top+'px';}
      else if(step.pos==='left'){box.style.left=Math.max(8,r.left-bw-12)+'px';box.style.top=r.top+'px';}
    }
  }
}

function tutNext(){sfx('click');tutStep++;showTutStep();}
function tutPrev(){sfx('click');tutStep--;showTutStep();}
function endTutorial(){
  tutActive=false;
  document.getElementById('tutOverlay').classList.remove('show');
  document.getElementById('tutSpot').style.display='none';
  document.getElementById('tutBox').style.display='none';
  document.getElementById('tutSkip').classList.remove('show');
  // Mark tutorial as seen
  S.tutSeen=true;save();
}

// Auto-show tutorial on first visit
if(!S.tutSeen){
  // Will trigger after entering the game
  const origEnter=enterGame;
  enterGame=function(){origEnter();setTimeout(()=>startTutorial(),800);};
}
