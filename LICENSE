/* ============================================
   SOUND ENGINE — Web Audio API oscillators
   ============================================ */
let audioCtx=null;
function getAC(){if(!audioCtx){audioCtx=new(window.AudioContext||window.webkitAudioContext)();} if(audioCtx.state==='suspended')audioCtx.resume(); return audioCtx;}
function playTone(freq,dur,type,vol){
  try{const ac=getAC();const o=ac.createOscillator();const g=ac.createGain();
  o.type=type||'square';o.frequency.value=freq;g.gain.value=vol||0.08;
  o.connect(g);g.connect(ac.destination);o.start();
  g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+dur);
  o.stop(ac.currentTime+dur);}catch(e){}
}
function sfx(type){
  switch(type){
    case 'click': playTone(800,.06,'square',.06); break;
    case 'success': playTone(523,.1,'square',.07);setTimeout(()=>playTone(659,.1,'square',.07),100);setTimeout(()=>playTone(784,.15,'square',.07),200); break;
    case 'err': playTone(200,.15,'sawtooth',.06);setTimeout(()=>playTone(150,.2,'sawtooth',.05),100); break;
    case 'levelup': playTone(523,.08,'square',.07);setTimeout(()=>playTone(659,.08,'square',.07),80);setTimeout(()=>playTone(784,.08,'square',.07),160);setTimeout(()=>playTone(1047,.2,'square',.08),240); break;
    case 'catch': playTone(1200,.05,'sine',.06); break;
    case 'miss': playTone(100,.1,'sawtooth',.05); break;
  }
}

/* ============================================
   CONFETTI SYSTEM
   ============================================ */
function fireConfetti(){
  const c=document.getElementById('confettiC');
  const ctx=c.getContext('2d');
  c.width=innerWidth;c.height=innerHeight;
  const cols=['#ffd700','#0fff95','#ff6ec7','#00d4ff','#c471ed','#ff4757'];
  const pieces=Array.from({length:80},()=>({
    x:innerWidth/2+(Math.random()-.5)*200,
    y:innerHeight/2,
    vx:(Math.random()-.5)*12,
    vy:-(Math.random()*12+4),
    w:Math.random()*8+4,
    h:Math.random()*6+2,
    col:cols[Math.floor(Math.random()*cols.length)],
    rot:Math.random()*360,
    rv:(Math.random()-.5)*10,
    g:0.25+Math.random()*0.15
  }));
  let frame=0;
  function draw(){
    ctx.clearRect(0,0,c.width,c.height);
    let alive=false;
    pieces.forEach(p=>{
      p.x+=p.vx;p.vy+=p.g;p.y+=p.vy;p.rot+=p.rv;p.vx*=0.99;
      if(p.y<c.height+50){
        alive=true;
        ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.rot*Math.PI/180);
        ctx.fillStyle=p.col;ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
        ctx.restore();
      }
    });
    frame++;
    if(alive&&frame<180)requestAnimationFrame(draw);
    else ctx.clearRect(0,0,c.width,c.height);
  }
  draw();
}

/* ============================================
   SCREEN SHAKE
   ============================================ */
function shakeScreen(){
  const el=document.getElementById('app');
  el.classList.remove('shake');
  void el.offsetWidth; // force reflow
  el.classList.add('shake');
  setTimeout(()=>el.classList.remove('shake'),400);
}

/* ============================================
   CHARACTER REACTIONS
   ============================================ */
function charReact(type){
  const av=document.querySelector('.tutor-avatar');
  if(!av)return;
  av.classList.remove('bounce','err-shake','idle');
  void av.offsetWidth;
  const base=tutorEmoji();
  switch(type){
    case 'win': av.classList.add('bounce');av.textContent='🎉';setTimeout(()=>{av.textContent=base;av.classList.remove('bounce');},1500); break;
    case 'err': av.classList.add('err-shake');av.textContent='😰';setTimeout(()=>{av.textContent=base;av.classList.remove('err-shake');},1000); break;
    case 'idle': av.classList.add('idle');av.textContent=base; break;
  }
}

