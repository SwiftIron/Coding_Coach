function runCode(){const code=document.getElementById('codeIn').value;const out=document.getElementById('outC'),st=document.getElementById('outSt');if(!code.trim()){out.innerHTML='<span class="oe">'+t('noCode')+'</span>';sfx('err');return;}sfx('click');const r=exec(code);if(r.err){out.innerHTML=`<span class="oe">${escH(r.out)}</span>`;st.textContent='✗ ERROR';st.style.color='var(--glow-red)';sfx('err');shakeScreen();charReact('err');}else{out.innerHTML=r.out?`<span class="od">${escH(r.out)}</span>`:'<span class="oi">(No output)</span>';st.textContent='✓ OK';st.style.color='var(--glow-green)';sfx('click');}}

function submitCode(){const code=document.getElementById('codeIn').value;const out=document.getElementById('outC');if(!code.trim()){out.innerHTML='<span class="oe">'+t('writeFirst')+'</span>';sfx('err');return;}sfx('click');const r=exec(code);if(r.err){out.innerHTML=`<span class="oe">${escH(r.out)}</span>\n<span class="oe">${t('fixError')}</span>`;sfx('err');shakeScreen();charReact('err');return;}out.innerHTML=r.out?`<span class="od">${escH(r.out)}</span>`:'';
// Check zone or puzzle
if(S.current&&S.current.startsWith('puzzle_')){const pid=S.current.replace('puzzle_','');const p=PUZZLES.find(p=>p.id===pid);if(p&&p.check(r.out)){complete(p.id+'_'+S.lang,p.xp,p.coins,L(p,'title'));document.getElementById('tutorMsg').textContent=t('tutorSuccess');charReact('win');}else{out.innerHTML+='\n<span class="oe">'+t('notQuite')+'</span>';toast(t('notQuiteToast'),'var(--glow-red)');document.getElementById('tutorMsg').textContent=t('tutorFail');sfx('err');shakeScreen();charReact('err');}}
else{const z=ZONES.find(z=>z.id===S.current);if(z&&z.check(r.out)){complete(z.id,z.xp,z.coins,L(z,'title'));document.getElementById('tutorMsg').textContent=t('tutorSuccess');charReact('win');}else{out.innerHTML+='\n<span class="oe">'+t('notQuite')+'</span>';toast(t('notQuiteToast'),'var(--glow-red)');document.getElementById('tutorMsg').textContent=t('tutorFail');sfx('err');shakeScreen();charReact('err');}}}

function complete(id,baseXp,coins,title){if(S.completed.has(id)){toast(t('alreadyDone'),'var(--glow-blue)');return;}S.completed.add(id);const xp=S.hintUsed?Math.floor(baseXp*.7):baseXp;S.coins+=coins;S.streak++;let lu=false;S.xp+=xp;while(S.xp>=S.xpReq){S.xp-=S.xpReq;S.level++;S.xpReq=Math.floor(S.xpReq*1.35);lu=true;}updHUD();save();particles(innerWidth/2,innerHeight/2);fireConfetti();sfx(lu?'levelup':'success');const titlesArr=S.i18n==='sv'?TITLES_SV:TITLES;
document.getElementById('moBox').innerHTML=`<div class="mo-i">${lu?'🌟':'⭐'}</div><div class="mo-t ok">${lu?t('levelUp'):t('questComplete')}</div><div class="mo-b">${title}</div><div class="mo-xp">+${xp} XP</div><div class="mo-co">+${coins} 🪙</div>${S.hintUsed?'<div style="color:var(--glow-gold);font-size:9px;margin-top:3px">'+t('hintPenalty')+'</div>':''}${lu?`<div style="font-family:Silkscreen;font-size:11px;color:var(--glow-pink);margin-top:5px">Level ${S.level} — ${titlesArr[Math.min(S.level-1,titlesArr.length-1)]}</div>`:''}  <button class="mo-btn" onclick="closeMo()">${t('continueBtn')}</button>`;
document.getElementById('modal').classList.add('show');}

