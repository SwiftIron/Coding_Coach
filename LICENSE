function showMiniGame(){
  document.getElementById('mgTitle').textContent='⚡ '+(S.i18n==='sv'?'KODFÅNGARE':'CODE CATCHER')+' ⚡';
  document.getElementById('mgSub').textContent=S.i18n==='sv'?'Klicka på BRA kod (gröna), undvik buggarna (röda)! 30 sekunder!':'Click the GOOD code (green), avoid the bugs (red)! 30 seconds!';
  document.getElementById('mgBtn').textContent=S.i18n==='sv'?'STARTA!':'START!';
  document.getElementById('mgBtn').onclick=startMiniGame;
  mgScore=0;mgTimer=30;mgCaught=[];
  document.getElementById('mgScore').textContent='SCORE: 0';
  document.getElementById('mgTimer').textContent='TIME: 30s';
  document.getElementById('mgArea').innerHTML='';
  document.getElementById('mgOverlay').classList.add('show');
  sfx('click');
}

function startMiniGame(){
  mgActive=true;mgScore=0;mgTimer=30;mgCaught=[];
  document.getElementById('mgBtn').textContent=S.i18n==='sv'?'⏭ HOPPA ÖVER':'⏭ SKIP';
  document.getElementById('mgBtn').onclick=function(){endMiniGame();};
  document.getElementById('mgArea').innerHTML='';
  document.getElementById('mgScore').textContent='SCORE: 0';
  
  mgInterval=setInterval(()=>{
    mgTimer--;
    document.getElementById('mgTimer').textContent='TIME: '+mgTimer+'s';
    if(mgTimer<=0){endMiniGame();}
  },1000);
  
  mgSpawnInterval=setInterval(()=>{
    if(!mgActive)return;
    spawnMGItem();
  },650);
  
  spawnMGItem();spawnMGItem();
}

function spawnMGItem(){
  const area=document.getElementById('mgArea');
  const item=MG_ITEMS[Math.floor(Math.random()*MG_ITEMS.length)];
  
  const el=document.createElement('div');
  el.className='mg-falling '+(item.good?'good':'bad');
  el.textContent=item.text;
  el.style.left=Math.random()*70+5+'%';
  el.style.top='-30px';
  
  el.onclick=function(e){
    e.stopPropagation();
    if(!mgActive)return;
    el.classList.add('caught');
    if(item.good){mgScore+=10;sfx('catch');mgCaught.push(item);}
    else{mgScore=Math.max(0,mgScore-15);sfx('miss');shakeScreen();}
    document.getElementById('mgScore').textContent='SCORE: '+mgScore;
    setTimeout(()=>el.remove(),200);
  };
  
  area.appendChild(el);
  
  let y=-30;
  const speed=1.2+Math.random()*1.3;
  function fall(){
    if(!mgActive||el.classList.contains('caught')){el.remove();return;}
    y+=speed;
    el.style.top=y+'px';
    if(y>210){el.remove();return;}
    requestAnimationFrame(fall);
  }
  requestAnimationFrame(fall);
}

function endMiniGame(){
  mgActive=false;
  clearInterval(mgInterval);
  clearInterval(mgSpawnInterval);
  document.getElementById('mgArea').innerHTML='';
  
  const bonus=Math.floor(mgScore/3);
  const coinBonus=Math.floor(bonus/5);
  if(bonus>0){S.xp+=bonus;S.coins+=coinBonus;while(S.xp>=S.xpReq){S.xp-=S.xpReq;S.level++;S.xpReq=Math.floor(S.xpReq*1.35);}updHUD();save();}
  
  sfx(mgScore>=60?'success':'click');
  if(mgScore>=60)fireConfetti();
  
  // Build educational recap
  const isEn=S.i18n==='en';
  // Deduplicate caught items
  const seen=new Set();
  const unique=mgCaught.filter(item=>{if(seen.has(item.text))return false;seen.add(item.text);return true;});
  
  let recap='<div class="mg-recap-hdr">'+(isEn?'📚 WHAT YOU CAUGHT — QUICK REVIEW':'📚 VAD DU FÅNGADE — SNABB GENOMGÅNG')+'</div><div class="mg-recap">';
  if(unique.length===0){
    recap+='<div class="mg-recap-item"><span class="mg-recap-desc">'+(isEn?'You didn\'t catch any code this time. Try clicking the green items next time!':'Du fångade ingen kod den här gången. Försök klicka på de gröna sakerna nästa gång!')+'</span></div>';
  } else {
    unique.slice(0,8).forEach(item=>{
      recap+='<div class="mg-recap-item"><span class="mg-recap-code">'+escH(item.text)+'</span><span class="mg-recap-desc">'+(isEn?item.en:item.sv)+'</span></div>';
    });
    if(unique.length>8) recap+='<div class="mg-recap-item"><span class="mg-recap-desc">...+'+(unique.length-8)+(isEn?' more items':' fler saker')+'</span></div>';
  }
  recap+='</div>';
  
  document.getElementById('mgScore').innerHTML='FINAL SCORE: '+mgScore+(bonus>0?' → +'+bonus+' XP!':'');
  document.getElementById('mgArea').innerHTML=recap;
  document.getElementById('mgArea').style.overflow='auto';
  document.getElementById('mgBtn').textContent=(isEn?'CLOSE':'STÄNG')+' (+'+bonus+' XP)';
  document.getElementById('mgBtn').onclick=function(){
    document.getElementById('mgOverlay').classList.remove('show');
    document.getElementById('mgArea').style.overflow='';
  };
}

