function showReset(){
  document.getElementById('rstTitle').textContent=S.i18n==='sv'?'⚠️ ÅTERSTÄLL FRAMSTEG?':'⚠️ RESET PROGRESS?';
  document.getElementById('rstMsg').textContent=S.i18n==='sv'?'Detta raderar ALL din framsteg, XP och klarade uppdrag. Är du säker?':'This will erase ALL your progress, XP, and completed quests. Are you sure?';
  document.getElementById('rstYes').textContent=S.i18n==='sv'?'JA, ÅTERSTÄLL':'YES, RESET';
  document.getElementById('rstNo').textContent=S.i18n==='sv'?'AVBRYT':'CANCEL';
  document.getElementById('rstModal').classList.add('show');
  sfx('click');
}
function cancelReset(){document.getElementById('rstModal').classList.remove('show');sfx('click');}
function confirmReset(){
  sfx('err');
  // Reset all state
  S.level=1;S.xp=0;S.xpReq=100;S.coins=0;S.streak=0;
  S.completed=new Set();S.current=null;S.hintUsed=false;
  // Clear storage
  if(uLS)try{localStorage.removeItem('cq4');}catch(e){}
  mem={};
  // Update UI
  updHUD();buildMap();buildPuzzles();goMap();updUI();
  document.getElementById('rstModal').classList.remove('show');
  toast(S.i18n==='sv'?'Framsteg återställd!':'Progress reset!','var(--glow-red)');
}

