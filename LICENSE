/* === STARS === */
function initS(id){const c=document.getElementById(id);if(!c)return;const ctx=c.getContext('2d');c.width=innerWidth;c.height=innerHeight;const st=Array.from({length:50},()=>({x:Math.random()*c.width,y:Math.random()*c.height,r:Math.random()*1.2+.3,a:Math.random(),s:Math.random()*.007+.002}));(function d(){ctx.clearRect(0,0,c.width,c.height);st.forEach(s=>{s.a+=s.s;ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fillStyle=`rgba(200,210,255,${.12+Math.abs(Math.sin(s.a))*.45})`;ctx.fill();});requestAnimationFrame(d);})();}

/* === HELPERS === */
function L(z,k){const v=z[k];return typeof v==='object'?v[S.i18n]||v.en:v;}
function escH(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function toast(m,c){const e=document.createElement('div');e.className='tt';e.style.borderColor=c;e.style.color=c;e.textContent=m;document.getElementById('toastA').appendChild(e);setTimeout(()=>e.remove(),3000);}
function particles(x,y){const cs=['#ffd700','#0fff95','#ff6ec7','#00d4ff'];for(let i=0;i<14;i++){const p=document.createElement('div');p.className='particle';const a=Math.random()*Math.PI*2,d=25+Math.random()*55;p.style.left=x+'px';p.style.top=y+'px';p.style.background=cs[i%4];p.style.setProperty('--dx',Math.cos(a)*d+'px');p.style.setProperty('--dy',Math.sin(a)*d+'px');document.body.appendChild(p);setTimeout(()=>p.remove(),800);}}

